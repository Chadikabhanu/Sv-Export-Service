# Application Port
PORT=8080

# Database Connection URL
DATABASE_URL=postgresql://user:password@localhost:5432/mydatabase

# Redis Connection URL
REDIS_URL=redis://localhost:6379

# Secret used for JWT auth on WebSocket handshake (dev value only - do not use in production)
JWT_SECRET=a_secure_secret_for_dev

# Directory (inside the app container) where generated CSV exports are written
EXPORTS_DIR=/app/exports

# Number of rows read from Postgres per streaming chunk
CHUNK_SIZE=10000
